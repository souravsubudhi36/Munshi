# ── Munshi Configuration ─────────────────────────────────────────────────────

# Anthropic API key (required for Claude AI features)
ANTHROPIC_API_KEY=your_key_here

# Claude model to use: claude-haiku-4-5-20251001 (fast/cheap) or claude-sonnet-4-6 (smarter)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file
DATABASE_URL=sqlite+aiosqlite:///./data/db/munshi.db

# ── Audio ─────────────────────────────────────────────────────────────────────
# Wake word sensitivity (0.0 - 1.0, lower = more sensitive)
WAKE_WORD_SENSITIVITY=0.5

# VAD aggressiveness (0-3, higher = more aggressive filtering)
VAD_AGGRESSIVENESS=2

# ── Sarvam AI (STT + TTS) ─────────────────────────────────────────────────────
# Get your key at https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_key_here

# STT model: saarika:v2 (recommended) or saarika:v1
SARVAM_STT_MODEL=saarika:v2

# TTS model
SARVAM_TTS_MODEL=bulbul:v1

# BCP-47 language code for STT + TTS
# Options: hi-IN, bn-IN, ta-IN, te-IN, kn-IN, ml-IN, gu-IN, mr-IN, pa-IN, en-IN
SARVAM_LANGUAGE_CODE=hi-IN

# TTS speaker voice (meera, pavithra, maitreyi, arvind, amol, amartya, diya, neel)
SARVAM_TTS_SPEAKER=meera

# ── Shop ──────────────────────────────────────────────────────────────────────
SHOP_NAME=My Shop
OWNER_NAME=Shop Owner
SHOP_LANGUAGE=hi

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change_this_to_a_random_secret

# ── Cloud Sync (Optional) ─────────────────────────────────────────────────────
# Leave blank to disable cloud sync
SUPABASE_URL=
SUPABASE_KEY=

# ── Hardware ──────────────────────────────────────────────────────────────────
# Platform: auto, raspberry_pi, android, desktop
PLATFORM=auto

# LED pin (Raspberry Pi GPIO pin for WS2812B LED ring)
LED_GPIO_PIN=18
LED_COUNT=8

# ── Paths ─────────────────────────────────────────────────────────────────────
MODELS_DIR=./data/models
WAKE_WORD_MODEL_PATH=./data/models/wake_word/munshi.onnx
